---
import Base from '../layouts/Base.astro';
---

<Base title="雕龙 DragonCraft — 叙事平权" locale="zh">
  <!-- Hero -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-eyebrow">叙事平权运动 · Narrative Equality Movement</div>
      <h1 class="hero-title">
        每个人都能讲好<br/>自己的故事
      </h1>
      <p class="hero-sub">
        雕龙是一套完整的叙事方法论操作系统。<br/>
        一本书 · 26个场景Skill · 工具矩阵 · 案例库
      </p>
      <div class="hero-actions">
        <a href="/book" class="cta">免费阅读书籍</a>
        <a href="/skills" class="cta-outline">探索Skill工具箱</a>
      </div>
    </div>
  </section>

  <!-- Core claim -->
  <section class="claim">
    <div class="claim-inner">
      <blockquote>
        "Many people can do great work.<br/>
        Few can tell great stories.<br/>
        Those who can do both are almost unstoppable."
      </blockquote>
      <p class="claim-zh">
        叙事不是修辞技巧，叙事是认知基础设施。<br/>
        让更多人掌握这个底层能力，是雕龙的使命。
      </p>
    </div>
  </section>

  <!-- Content pillars — 2x2 grid -->
  <section class="pillars">
    <div class="pillars-inner">
      <div class="pillar-card">
        <div class="pillar-icon">📖</div>
        <h3>书籍</h3>
        <p>《叙事引擎：AI时代的内容操作系统》<br/>22章完整方法论</p>
        <a href="/book">开始阅读 →</a>
      </div>
      <div class="pillar-card">
        <div class="pillar-icon">🎯</div>
        <h3>26个场景Skill</h3>
        <p>个人IP、品牌故事、危机公关、销售说服……<br/>每个场景都有可操作的叙事框架</p>
        <a href="/skills">探索Skill →</a>
      </div>
      <div class="pillar-card">
        <div class="pillar-icon">🛠️</div>
        <h3>工具箱</h3>
        <p>八刀评估表 · 叙事人格测试 · 15+模板<br/>让叙事能力可衡量、可练习</p>
        <a href="/tools">使用工具 →</a>
      </div>
      <div class="pillar-card">
        <div class="pillar-icon">📚</div>
        <h3>案例库</h3>
        <p>真实叙事案例 + 打磨前后对比<br/>从真实故事中学习叙事的力量</p>
        <a href="/examples">查看案例 →</a>
      </div>
    </div>
  </section>

  <!-- GitHub CTA -->
  <section class="github-cta">
    <div class="github-cta-inner">
      <h2>开源协作 · 共同进化</h2>
      <p>
        你的案例、你的Skill、你的翻译，都在帮助更多人。<br/>
        GitHub 社区正在生长——成为叙事平权运动的一部分。
      </p>
      <a href="https://github.com/lj22503/diaolong-skill" target="_blank" class="cta">
        访问 GitHub →
      </a>
    </div>
  </section>
</Base>

<style>
  .hero {
    background: linear-gradient(160deg, #fafaf8 0%, #f0ece8 100%);
    border-bottom: 1px solid var(--border);
  }
  .hero-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 100px 24px 80px;
  }
  .hero-eyebrow {
    font-size: 0.8rem;
    color: var(--accent);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 20px;
  }
  .hero-title {
    font-family: var(--font-serif);
    font-size: 3.2rem;
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: 20px;
    color: var(--text);
  }
  .hero-sub {
    font-size: 1.1rem;
    color: var(--text-muted);
    line-height: 1.8;
    margin-bottom: 36px;
  }
  .hero-actions { display: flex; gap: 16px; flex-wrap: wrap; }

  .claim {
    border-bottom: 1px solid var(--border);
  }
  .claim-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 64px 24px;
    text-align: center;
  }
  .claim blockquote {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-style: italic;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 24px;
  }
  .claim-zh {
    font-size: 1rem;
    color: var(--text);
    line-height: 1.8;
  }

  .pillars {
    border-bottom: 1px solid var(--border);
  }
  .pillars-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 64px 24px;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  .pillar-card {
    padding: 28px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: white;
  }
  .pillar-icon { font-size: 2rem; margin-bottom: 16px; }
  .pillar-card h3 { font-size: 1rem; font-weight: 600; margin-bottom: 10px; }
  .pillar-card p { color: var(--text-muted); font-size: 0.88rem; line-height: 1.7; margin-bottom: 16px; }
  .pillar-card a { font-size: 0.88rem; color: var(--accent); font-weight: 500; }
  .pillar-card a:hover { color: var(--accent-hover); }

  .github-cta {
    background: var(--text);
    color: white;
  }
  .github-cta-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 80px 24px;
    text-align: center;
  }
  .github-cta h2 {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 16px;
  }
  .github-cta p {
    color: rgba(255,255,255,0.7);
    font-size: 1rem;
    line-height: 1.8;
    margin-bottom: 32px;
  }
  .github-cta .cta { background: white; color: var(--text); }
  .github-cta .cta:hover { background: #f0f0f0; }

  @media (max-width: 640px) {
    .pillars-inner { grid-template-columns: 1fr; }
  }
</style>

0\u5199\u7684\u662f\u201cXX\u516c\u53f8\u521b\u59cb\u4eba\u201d\u8fd8\u662f\u201c\u6211\u4e3a\u4ec0\u4e48\u505a\u4e86\u8fd9\u4ef6\u4e8b\u201d\uff1f\u524d\u8005\u662f\u7b80\u5386\uff0c\u540e\u8005\u662f\u6545\u4e8b\u3002","content":"\u6253\u5f00\u4f60\u7684LinkedIn\uff0c\u6216\u8005\u7ffb\u5230\u4f60\u7684\u516c\u4f17\u53f7\u4ecb\u7ecd\u9875\uff0c\u6216\u8005\u770b\u770b\u4f60\u7684\u5fae\u4fe1\u7b7e\u540d\u3002\n\n\u4f60\u5199\u7684\u662f\u4ec0\u4e48\uff1f\n\n\u201cXX\u516c\u53f8\u521b\u59cb\u4eba\uff0c\u5e2e\u52a91000+\u5ba2\u6237\u5b9e\u73b0\u589e\u957f\u3002\u201d\n\n\u201c\u8d44\u6df1\u4ea7\u54c1\u7ecf\u7406\uff0c\u5584\u4e8e\u4ece0\u52301\uff0c\u70ed\u7231\u6311\u6218\u3002\u201d\n\n\u201c\u77e5\u8bc6\u535a\u4e3b\uff0c\u5206\u4eab\u81ea\u5f8b\u4e0e\u6210\u957f\uff0c\u966a\u4f60\u4e00\u8d77\u53d8\u597d\u3002\u201d\n\n\u8fd9\u4e09\u53e5\u8bdd\uff0c\u4e5f\u8bb8\u771f\u5b9e\uff0c\u4f46\u6beb\u65e0\u8bb0\u5fc6\u70b9\u3002\n\n\u8bfb\u5b8c\uff0c\u4f60\u53ea\u77e5\u9053\u8fd9\u4e2a\u4eba\u7684title\u548c\u505a\u4e86\u4ec0\u4e48\u2014\u2014\u4f46\u4f60\u4e0d\u77e5\u9053\u4ed6\u662f\u8c01\u3002\u4f60\u4e0d\u77e5\u9053\u4ed6\u4e3a\u4ec0\u4e48\u505a\u8fd9\u4ef6\u4e8b\uff0c\u4e0d\u77e5\u9053\u4ed6\u7ecf\u5386\u8fc7\u4ec0\u4e48\uff0c\u4e0d\u77e5\u9053\u4ed6\u503c\u4e0d\u503c\u5f97\u76f8\u4fe1\u4efb\u3002\n\n\u4e8b\u5b9e\u8ba9\u4eba\u201c\u77e5\u9053\u201d\uff0c\u6545\u4e8b\u8ba9\u4eba\u201c\u8bb0\u4f4f\u201d\u3002\n\n\u8fd9\u4e00\u7ae0\uff0c\u89e3\u51b3LinkedIn/\u4e2a\u4eba\u54c1\u724c\u9875\u9762\u7684\u53d9\u4e8b\u5347\u7ea7\u95ee\u9898\u3002"},{"id":"c13b","num":"C20","title":"\u63a2\u7d22\u5f0f\u53d9\u4e8b\uff1a\u8ba9\u7528\u6237\u81ea\u5df1\u53d1\u73b0\u5f69\u86cb","part":3,"desc":"\u76f4\u63a5\u544a\u8f9f\u7528\u6237\u201c\u6211\u4eec\u4ea7\u54c1\u597d\u201d\uff0c\u7528\u6237\u76f4\u63a5\u5212\u8d70\u3002\u81ea\u5df1\u63a2\u7d22\u51fa\u6765\u7684\u7ed3\u8bba\uff0c\u4fe1\u4efb\u5ea6\u662f\u63a5\u6536\u544a\u8f9f\u76843\u500d\u3002","content":"\u5237\u5230\u4e00\u4e2a\u5e7f\u544a\uff0c\u660e\u660e\u767d\u767d\u544a\u8f9f\u4f60\u201c\u6211\u4eec\u4ea7\u54c1\u597d\u201d\uff0c\u4f60\u76f4\u63a5\u5212\u8d70\u3002\n\n\u4f46\u6709\u65f6\u5019\uff0c\u4f60\u4f1a\u9047\u5230\u4e00\u4e2a\u54c1\u724c\uff0c\u5b83\u6545\u610f\u628a\u6545\u4e8b\u85cf\u8d77\u6765\uff0c\u8ba9\u4f60\u81ea\u5df1\u53bb\u627e\u3002\n\n\u627e\u5230\u7684\u90a3\u4e00\u523b\uff0c\u4f60\u5fc3\u91cc\u90a3\u4e2a\u723d\u2014\u2014\u6bd4\u5b83\u76f4\u63a5\u544a\u8f9f\u4f60\u5f3f767\u5341\u500d\u3002\n\n\u8fd9\u79cd\u53d9\u4e8b\u65b9\u5f0f\uff0c\u53eb\u505a\u201c\u63a2\u7d22\u5f0f\u53d9\u4e8b\u201d\u3002\n\n\u6838\u5fc3\u903b\u8f91\uff1a\u4eba\u5bf9\u81ea\u5df1\u53d1\u73b0\u7684\u4e1c\u897f\uff0c\u4fe1\u4efb\u5ea6\u662f\u63a5\u6536\u544a\u8f9f\u76843\u500d\u3002\n\nGoogle Chrome Dino\u628a\u65ad\u7f51\u53d8\u6210\u6e38\u620f\u3002\n\n\u5bc6\u5ba4\u9003\u8131\u4f5c\u4e3a\u53d9\u4e8b\u5373\u4f53\u9a8c\u7684\u5546\u4e1a\u573a\u666f\u3002\n\n\u300a\u9ed1\u795e\u8bdd\u4e50\u90ce\u300b\u7528\u60ac\u5ff5\u5f0f\u9884\u70ed\u5f15\u7206\u5168\u7403\u3002\n\n\u4e09\u4e2a\u6848\u4f8b\uff0c\u4e09\u79cd\u5f62\u5f0f\uff0c\u6838\u5fc3\u89c4\u5f8b\u662f\u4e00\u6837\u7684\uff1a\u4e0d\u8981\u544a\u8f9f\u7528\u6237\u201c\u8fd9\u662f\u4ec0\u4e48\u201d\uff0c\u8ba9\u4ed6\u4eec\u81ea\u5df1\u53d1\u73b0\u201c\u8fd9\u662f\u4ec0\u4e48\u201d\u3002"},{"id":"c20b","num":"C21","title":"\u53d9\u4e8b\u6280\u80fd\u7684\u6301\u7eed\u8fdb\u5316","part":3,"desc":"\u53d9\u4e8b\u80fd\u529b\u4e0d\u662f\u5b66\u4e00\u6b21\u5c31\u591f\u4e86\u2014\u2014\u662f\u4e00\u5957\u6301\u7eed\u8fed\u4ee3\u7684\u7cfb\u7edf\u3002\u4ece\u523b\u610f\u7ec3\u4e60\u5230\u76f4\u89c9\u5185\u5316\uff0c\u901a\u5411\u53d9\u4e8b\u81ea\u7531\u3002","content":"\u53d9\u4e8b\u6280\u80fd\u4e0d\u662f\u5b66\u4e00\u6b21\u5c31\u591f\u4e86\u3002\n\n\u5b83\u662f\u4e00\u5957\u6301\u7eed\u8fed\u4ee3\u7684\u7cfb\u7edf\u3002\n\n\u9636\u6bb51\uff1a\u523b\u610f\u7ec3\u4e60\u3002\u4f60\u5b66\u4e86\u4e00\u4e2a\u6846\u67b6\uff0c\u7136\u540e\u5728\u6bcf\u4e2a\u573a\u666f\u523b\u610f\u4f7f\u7528\u5b83\u3002\n\n\u9636\u6bb52\uff1a\u6709\u610f\u8bc6\u7684\u4f7f\u7528\u3002\u4f60\u5f00\u59cb\u80fd\u5728\u9002\u5f53\u7684\u573a\u666f\u81ea\u52a8\u8c03\u7528\u9002\u5f53\u7684\u65b9\u6cd5\u3002\n\n\u9636\u6bb53\uff1a\u76f4\u89c9\u5185\u5316\u3002\u4f60\u4e0d\u518d\u60f3\u201c\u6211\u8981\u7528\u4ec0\u4e48\u6846\u67b6\u201d\uff0c\u6846\u67b6\u5df2\u7ecf\u6210\u4e3a\u4f60\u7684\u672c\u80fd\u53cd\u5e94\u3002\n\n\u9636\u6bb54\uff1a\u81ea\u7531\u521b\u9020\u3002\u4f60\u5f00\u59cb\u6253\u7834\u6846\u67b6\uff0c\u521b\u9020\u65b0\u7684\u53d9\u4e8b\u65b9\u5f0f\u3002\n\n\u8fd9\u4e0d\u662f\u4e00\u6761\u7ebf\u6027\u7684\u8def\u5f84\uff0c\u800c\u662f\u5faa\u73af\u5f80\u590d\u7684\u8fc7\u7a0b\u3002\n\n\u6bcf\u4e2a\u9636\u6bb5\u6709\u6bcf\u4e2a\u9636\u6bb5\u7684\u91cd\u70b9\u7ec3\u4e60\u3002\u8fd9\u4e00\u7ae0\u7ed9\u51fa\u6bcf\u4e2a\u9636\u6bb5\u7684\u5177\u4f53\u64cd\u4f5c\u65b9\u6cd5\u3002"}];
  var chaptersById = {};
  for (var i = 0; i < chapters.length; i++) {
    chaptersById[chapters[i].id] = chapters[i];
  }

  function showChapter(id) {
    document.querySelectorAll('.sidebar-chap').forEach(function(el) {
      el.classList.toggle('active', el.dataset.id === id);
    });
    var ch = chaptersById[id];
    if (!ch) return;
    var partNames = {1: 'Part 1 Foundations', 2: 'Part 2 Scenario Skills', 3: 'Part 3 AI-Era Mastery'};
    var paras = ch.content.split('\n');
    var bodyHtml = '';
    for (var j = 0; j < paras.length; j++) {
      var p = paras[j].trim();
      if (p) {
        bodyHtml += '<p>' + p + '</p>';
      }
    }
    var html = '<div class="chapter-header">' +
      '<div class="chapter-meta">' +
        '<span class="chapter-part">' + partNames[ch.part] + '</span>' +
        '<span class="chapter-num">' + ch.num + '</span>' +
      '</div>' +
      '<h1 class="chapter-title">' + ch.title + '</h1>' +
      '<p class="chapter-desc">' + ch.desc + '</p>' +
    '</div>' +
    '<div class="chapter-body">' + bodyHtml + '</div>' +
    '<div class="chapter-footer">' +
      '<a href="https://github.com/lj22503/diaolong-skill" target="_blank" class="chapter-github-link">Read full chapter on GitHub →</a>' +
    '</div>';
    document.getElementById('book-content').innerHTML = html;
  }

  function togglePart(part) {
    var chaptersEl = document.getElementById('part-' + part + '-chapters');
    var btn = document.querySelector('.sidebar-part[data-part="' + part + '"]');
    var toggle = btn.querySelector('.sidebar-toggle');
    var isOpen = chaptersEl.style.display !== 'none';
    if (isOpen) {
      chaptersEl.style.display = 'none';
      toggle.textContent = '+';
    } else {
      chaptersEl.style.display = 'block';
      toggle.textContent = '-';
    }
  }

  showChapter('intro');
</script>


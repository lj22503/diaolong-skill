        <div class="chapter-item">
          <span class="chapter-num">C15</span>
          <span class="chapter-title">Meta-Skill: Self-Iterating Narrative Systems</span>
          <div class="chapter-versions">
            <a href="https://github.com/lj22503/diaolong-skill/tree/main/chapters" target="_blank" class="chapter-link">GitHub</a>
          </div>
        </div>
        <div class="chapter-item">
          <span class="chapter-num">C19</span>
          <span class="chapter-title">Personal IP Narrative Construction</span>
          <div class="chapter-versions">
            <a href="https://github.com/lj22503/diaolong-skill/tree/main/chapters" target="_blank" class="chapter-link">GitHub</a>
          </div>
        </div>
        <div class="chapter-item">
          <span class="chapter-num">C22</span>
          <span class="chapter-title">Narrative Leadership</span>
          <div class="chapter-versions">
            <a href="https://github.com/lj22503/diaolong-skill/tree/main/chapters" target="_blank" class="chapter-link">GitHub</a>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <h2 class="section-title">All Chapters on GitHub</h2>
      <p style="color: var(--text-muted); margin-bottom: 16px;">Complete book (Chinese + English notes) available on GitHub.</p>
      <a href="https://github.com/lj22503/diaolong-skill/tree/main/chapters" target="_blank" class="cta">View on GitHub</a>
    </section>
  </div>
</Base>

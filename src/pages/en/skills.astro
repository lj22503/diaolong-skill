<style>
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 16px;
    margin-bottom: 48px;
  }
  .skill-card {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 20px;
    background: white;
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .skill-card:hover {
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
    transform: translateY(-2px);
  }
  .skill-cat {
    display: inline-block;
    font-size: 0.7rem;
    color: var(--accent);
    background: rgba(192,57,43,0.08);
    padding: 2px 8px;
    border-radius: 3px;
    margin-bottom: 10px;
  }
  .skill-card h3 { font-size: 0.95rem; font-weight: 600; margin-bottom: 8px; }
  .skill-card p { color: var(--text-muted); font-size: 0.85rem; line-height: 1.6; margin-bottom: 12px; }
  .skill-card a { font-size: 0.82rem; color: var(--accent); font-weight: 500; }
  .skill-card a:hover { color: var(--accent-hover); }
  .meta-section {
    background: var(--bg-secondary);
    border-radius: var(--radius);
    padding: 20px 24px;
  }
  .meta-note { font-size: 0.9rem; color: var(--text-muted); line-height: 1.7; }
  .meta-note code {
    background: rgba(0,0,0,0.06);
    padding: 1px 5px;
    border-radius: 3px;
    font-size: 0.85em;
  }
</style>

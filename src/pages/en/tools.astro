---
import Base from '../../layouts/Base.astro';
---

<Base title="Tools — DragonCraft" locale="en">
  <div class="page-header">
    <h1>Tools</h1>
    <p>Make narrative capability measurable and practivable</p>
  </div>

  <div class="page-content">
    <div class="card-grid">
      <div class="card">
        <span class="card-tag">Community</span>
        <h3>DragonCraft Lab</h3>
        <p>Discussing interesting topics with friends. Join our knowledge community.</p>
        <a href="https://t.zsxq.com/CLU1d" target="_blank">Join →</a>
      </div>
      <div class="card">
        <span class="card-tag">Evaluation</span>
        <h3>Eight-Cut Evaluation</h3>
        <p>Evaluate narrative quality across 8 dimensions: history, dialectics, phenomenon, language, form, existence, aesthetics, and meta-reflection.</p>
        <a href="https://github.com/lj22503/diaolong-skill/blob/main/tools/八刀评估提示词.md" target="_blank">View →</a>
      </div>
      <div class="card">
        <span class="card-tag">Test</span>
        <h3>Narrative Personality Test</h3>
        <p>Discover your narrative style type: INTJ Strategic / ENFJ Inspiring / ENFP Creative / INFJ Metaphorical</p>
        <a href="/en/tools/narrative-personality-test.html" target="_blank">Take Test →</a>
      </div>
      <div class="card">
        <span class="card-tag">Templates</span>
        <h3>15+ Scenario Templates</h3>
        <p>Personal IP, brand stories, product launches, pitch decks, sales scripts... ready to use.</p>
        <a href="https://github.com/lj22503/diaolong-skill/tree/main/templates" target="_blank">GitHub →</a>
      </div>
    </div>
  </div>
</Base>

<style>
  .card a { font-size: 0.82rem; color: var(--accent); margin-top: 10px; display: inline-block; }
</style>

---
import Base from '../../layouts/Base.astro';
---

<Base title="Tools — DragonCraft" locale="en">
  <div class="page-header">
    <h1>Tools</h1>
    <p>Make narrative capability measurable and practivable</p>
  </div>

  <div class="page-content">
    <div class="card-grid">

      <div class="card">
        <span class="card-tag">Test</span>
        <h3>Narrative Personality Test</h3>
        <p>8 questions to discover your style: INTJ Strategic / ENFJ Inspiring / ENFP Creative / INFJ Metaphorical</p>
        <a href="/en/tools/narrative-personality-test.html" target="_blank">Take Test →</a>
      </div>

      <div class="card">
        <span class="card-tag">Eval</span>
        <h3>Eight-Cut Evaluation</h3>
        <p>Assess narrative quality across 8 dimensions: history, dialectics, phenomenon, language, form, existence, aesthetics, meta-reflection.</p>
        <a href="https://github.com/lj22503/diaolong-skill/blob/main/tools/八刀评估提示词.md" target="_blank">View →</a>
      </div>

      <div class="card">
        <span class="card-tag">Templates</span>
        <h3>15+ Scenario Templates</h3>
        <p>Personal IP, brand stories, product launches, pitch decks, sales scripts, crisis PR, social media… ready to use or adapt.</p>
        <a href="https://github.com/lj22503/diaolong-skill/tree/main/templates" target="_blank">GitHub →</a>
      </div>

      <div class="card">
        <span class="card-tag">Community</span>
        <h3>DragonCraft Lab</h3>
        <p>Discussing interesting topics with friends. Join our knowledge community.</p>
        <a href="https://t.zsxq.com/CLU1d" target="_blank">Join →</a>
      </div>

    </div>
  </div>
</Base>

<style>
  .card-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .card {
    background: var(--bg-secondary);
    border: 1.5px solid var(--border);
    border-radius: var(--radius);
    padding: 24px;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .card:hover {
    border-color: var(--accent);
    box-shadow: 0 2px 12px rgba(192,57,43,0.06);
  }

  .card-tag {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .card h3 {
    font-size: 1rem;
    font-weight: 600;
    margin: 8px 0 6px;
  }

  .card p {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 12px;
  }

  .card a {
    font-size: 0.82rem;
    color: var(--accent);
    font-weight: 500;
  }

  @media (max-width: 600px) {
    .card-grid { grid-template-columns: 1fr; }
  }
</style>
